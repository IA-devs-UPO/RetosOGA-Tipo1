# AI Provider Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Set the active provider (default: google)
PROVIDER=google

# =============================================================================
# GOOGLE PROVIDER (Default)
# =============================================================================
# Get your API key at: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# OLLAMA PROVIDER (Local)
# =============================================================================
# Base URL for local Ollama instance (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# NVIDIA PROVIDER
# =============================================================================
# Get your API key at: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# =============================================================================
# OPENROUTER PROVIDER
# =============================================================================
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Override the default model (anthropic/claude-3.5-sonnet)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# =============================================================================
# CUSTOM PROVIDER (OpenAI-compatible endpoints)
# =============================================================================
# API key for your custom endpoint
CUSTOM_API_KEY=your-custom-api-key-here

# Base URL for OpenAI-compatible endpoint
CUSTOM_ENDPOINT=https://your-service.openai.com/v1

# Optional: Model name (default: gpt-4)
CUSTOM_MODEL=gpt-4